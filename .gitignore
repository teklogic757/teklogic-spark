# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/next-build/
/out/
/.next_old_v2/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# logs
*.log
server.log

# Windows artifacts
nul

# local agent tooling
/.claude/
/.codex/
/.cursor/

# Supabase local state
/supabase/.temp/

# env files (can opt-in for committing if needed)
.env*
!.env.example
.envrc
.envrc.local

# vercel
.vercel

# local planning recovery artifacts
/.planning/recovery/

# build and cache state
/.turbo/
/.cache/

# typescript
*.tsbuildinfo
next-env.d.ts
